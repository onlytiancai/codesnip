{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "db:generate": "pnpm -w --filter database db:generate",
    "db:push": "pnpm -w --filter database db:push",
    "db:migrate": "pnpm -w --filter database db:migrate",
    "db:seed": "pnpm -w --filter database db:seed"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@nuxt/ui": "latest",
    "nuxt": "latest",
    "vue": "latest",
    "vue-router": "latest"
  },
  "devDependencies": {
    "@nuxt/devtools": "latest",
    "@testing-library/vue": "latest",
    "@vitejs/plugin-vue": "latest",
    "@vue/test-utils": "latest",
    "eslint": "^9.24.0",
    "happy-dom": "latest",
    "prisma": "5.22.0",
    "typescript": "latest",
    "vitest": "latest"
  }
}
