    "@prisma/client": "^6.19.2",
    "@vitalets/google-translate-api": "^9.2.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "github-markdown-css": "^5.9.0",
    "jsdom": "^29.0.0",
    "marked": "^17.0.4",
    "nuxt": "^4.3.1",
    "nuxt-auth-utils": "^0.5.29",
    "phonemize": "^1.1.0",
    "tailwindcss": "^4.2.1",
