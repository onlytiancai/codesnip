generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  provider          String
  providerAccountId String
  access_token      String?
  refresh_token     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Article {
  id             Int              @id @default(autoincrement())
  title          String
  slug           String           @unique
  excerpt        String?
  cover          String?
  content        String?
  splitContent   Json?            // Structured split content: { paragraphs: [...], sentences: [...] }
  status         String           @default("draft")
  difficulty     String           @default("beginner")
  views          Int              @default(0)
  bookmarks      Int              @default(0)
  publishAt      DateTime?
  metaTitle      String?
  metaDesc       String?
  categoryId     Int?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @default(now())
  authorId       Int
  importTaskId  Int?            @unique
  User           User             @relation(fields: [authorId], references: [id])
  Category       Category?        @relation(fields: [categoryId], references: [id])
  ImportQueue    ImportQueue?     @relation(fields: [importTaskId], references: [id], onDelete: SetNull)
  ArticleTag     ArticleTag[]
  Bookmark       Bookmark[]
  ReadingHistory ReadingHistory[]
  Sentence       Sentence[]
  Vocabulary     Vocabulary[]
}

model ArticleTag {
  articleId Int
  tagId     Int
  Tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  Article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  userId    Int
  articleId Int
  createdAt DateTime @default(now())
  Article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  description String?
  icon        String?
  color       String    @default("#3b82f6")
  status      String    @default("active")
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())
  Article     Article[]
}

model Membership {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  plan      String    @default("free")
  startDate DateTime  @default(now())
  endDate   DateTime?
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id            Int       @id @default(autoincrement())
  orderNo       String    @unique        // Merchant order number
  userId        Int
  plan          String                     // pro / annual
  amount        Int                        // Amount in cents (分)
  status        String    @default("pending")  // pending / paid / failed / refunded
  paymentMethod String    @default("wechat")   // wechat
  transactionId String?                     // WeChat Pay transaction ID
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  expiredAt     DateTime                    // Order expiration time (30 minutes)
  User          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model ReadingHistory {
  id           Int       @id @default(autoincrement())
  userId       Int
  articleId    Int
  progress     Int       @default(0)
  readingTime  Int       @default(0)
  lastReadAt   DateTime  @default(now())
  completedAt  DateTime?
  Article      Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  User         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
}

model Sentence {
  id        Int     @id @default(autoincrement())
  articleId Int
  order     Int
  en        String
  cn        String?
  audio     String?
  Article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Tag {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  slug        String       @unique
  description String?
  color       String       @default("#3b82f6")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now())
  ArticleTag  ArticleTag[]
}

model User {
  id              Int              @id @default(autoincrement())
  email           String           @unique
  name            String?
  password        String?
  avatar          String?
  role            String           @default("USER")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @default(now())
  bio             String?
  Account         Account[]
  Article         Article[]
  Bookmark        Bookmark[]
  Membership      Membership?
  Order           Order[]
  ReadingHistory  ReadingHistory[]
  UserPreferences UserPreferences?
  Vocabulary      Vocabulary[]
}

model UserPreferences {
  id                Int     @id @default(autoincrement())
  userId            Int     @unique
  englishLevel      String  @default("intermediate")
  dailyGoal         Int     @default(10)
  audioSpeed        Float   @default(1.0)
  theme             String  @default("system")
  fontSize          Int     @default(16)
  interests         String?
  reminderEnabled   Boolean @default(true)
  newArticleNotify  Boolean @default(true)
  vocabReviewNotify Boolean @default(false)
  marketingEmails   Boolean @default(false)
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vocabulary {
  id           Int       @id @default(autoincrement())
  userId       Int
  word         String
  phonetic     String?
  definition   String
  example      String?
  progress     Int       @default(0)
  articleId    Int?
  createdAt    DateTime  @default(now())
  lastReviewAt DateTime?
  User         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Article      Article?  @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@unique([userId, word])
}

model ImportQueue {
  id          Int           @id @default(autoincrement())
  url         String
  status      String        @default("pending") // pending, processing, completed, failed, cancelled
  stage       String        @default("init")    // init, fetch, extract, convert, images, done
  progress    Int           @default(0)         // 0-100 percentage
  totalImages Int           @default(0)
  processedImages Int       @default(0)
  result      Json?                             // { title, markdown, images: [...] }
  error       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now())
  Article     Article?
  ImportImage ImportImage[]

  @@index([status])
  @@index([createdAt])
}

model ImportImage {
  id          Int         @id @default(autoincrement())
  queueId     Int
  originalUrl String
  localPath   String?
  status      String      @default("pending") // pending, downloading, completed, failed
  error       String?
  createdAt   DateTime    @default(now())
  ImportQueue ImportQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@index([queueId])
}
