# Session encryption key (generate a secure random string)
NUXT_SESSION_PASSWORD=your-secret-key-at-least-32-chars-long

# Database
DATABASE_URL="file:./prisma/dev.db"

# GitHub OAuth
NUXT_OAUTH_GITHUB_CLIENT_ID=your-github-client-id
NUXT_OAUTH_GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth
NUXT_OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret

# WeChat Open Platform - Get from https://open.weixin.qq.com
NUXT_OAUTH_WECHAT_CLIENT_ID=your-wechat-appid
NUXT_OAUTH_WECHAT_CLIENT_SECRET=your-wechat-appsecret

# WeChat Official Account (公众号) - Get from https://mp.weixin.qq.com
NUXT_OAUTH_WECHAT_MP_APPID=your-mp-appid
NUXT_OAUTH_WECHAT_MP_SECRET=your-mp-secret

# App base URL (for OAuth redirect URI, e.g. https://example.com)
NUXT_PUBLIC_BASE_URL=https://example.com