# LLM Configuration
LLM_PROVIDER=openai  # openai or anthropic
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-6

# Custom API URLs (optional, leave empty for default)
# Useful for using custom endpoints like Azure OpenAI, local LLMs, or proxies
OPENAI_API_BASE=  # e.g., https://api.openai.com/v1 or http://localhost:8000/v1
ANTHROPIC_API_BASE=  # e.g., https://api.anthropic.com

# Application Settings
PROJECTS_DIR=./projects
DEFAULT_TRANSLATION_MODE=normal  # fast, normal, fine
DEFAULT_TARGET_LANGUAGE=中文